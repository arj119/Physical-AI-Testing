# =============================================================================
# QA Cell Edge Agent — Environment Configuration
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# -- Foundry Connection -------------------------------------------------------
FOUNDRY_URL=https://<your-stack>.palantirfoundry.com
CLIENT_ID=<from third-party app registration>
CLIENT_SECRET=<from third-party app registration>

# -- Stream RIDs (find in Foundry: Dataset > Overview > Resource identifier) --
VISION_STREAM_RID=<your-vision-stream-rid>
GRIP_STREAM_RID=<your-grip-stream-rid>
TELEMETRY_STREAM_RID=<your-telemetry-stream-rid>

# -- Robot Identity -----------------------------------------------------------
ROBOT_ID=robot-jetson-01
ROBOT_NAME=QA Cell Robot 01

# -- Hardware (auto-discovered if not set) ------------------------------------
# Leave commented to auto-detect. Set explicitly to override discovery.
# CAMERA_DEVICE_INDEX=0          # auto-scans /dev/video* for working USB camera
# MYCOBOT_PORT=/dev/ttyUSB0      # auto-scans USB serial ports (CP210x/CH340)
MYCOBOT_BAUD=115200

# -- Mock Mode (set to true for development without hardware) -----------------
MOCK_HARDWARE=false
MOCK_FOUNDRY=false

# -- Detection mode -----------------------------------------------------------
# "color" = HSV color detection (no model needed, sorts by block color)
# "model" = YOLOv5 inference + sensor fusion (needs trained model)
DETECTION_MODE=color
MODEL_PATH=./models/yolov5n.onnx

# -- Tuning -------------------------------------------------------------------
CAPTURE_INTERVAL_SEC=1.0
CONFIDENCE_THRESHOLD=0.75
GRIP_TOLERANCE=0.65
MODEL_POLL_INTERVAL_SEC=60
COMMAND_POLL_INTERVAL_SEC=1
HEARTBEAT_INTERVAL_SEC=5

# -- Closed-loop pick parameters ---------------------------------------------
# Camera→J6 yaw offset, in degrees. Run scripts/calibrate_yaw_offset.py once.
CAMERA_ROTATION_OFFSET_DEG=0.0
# Maximum retries on a missed grasp (gripper load below threshold).
MAX_PICK_RETRIES=2
# Minimum normalised gripper load (0..1) considered a successful grasp.
# Tune with scripts/calibrate_grip_threshold.py.
GRIP_LOAD_SUCCESS_THRESHOLD=0.15
# Dwell after closing the gripper before reading load.
GRIP_VERIFY_DELAY_S=0.4
# XY nudge on retry when the re-detected pose hasn't moved.
RETRY_NUDGE_MM=1.5

# -- Multi-frame pose smoothing (PoseBuffer) ---------------------------------
POSE_BUFFER_N=5
POSE_BUFFER_XY_TOL_MM=3.0
POSE_BUFFER_YAW_TOL_DEG=5.0

# -- Bin routing for colour sorting ------------------------------------------
# When set, takes precedence over fusion-decision → bin mapping.
# Format: "yellow:BIN_A,green:BIN_B,red:BIN_C"
# CLASS_TO_BIN=

# -- Workspace geometry ------------------------------------------------------
# Z height (mm in robot base frame) of the gooseneck horizontal beam.
# TRANSIT_HEIGHT_MM should sit comfortably below this.
GOOSENECK_BEAM_Z_MM=350

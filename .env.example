# =============================================================================
# QA Cell Edge Agent — Environment Configuration
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# -- Foundry Connection -------------------------------------------------------
FOUNDRY_URL=https://<your-stack>.palantirfoundry.com
CLIENT_ID=<from third-party app registration>
CLIENT_SECRET=<from third-party app registration>

# -- Stream RIDs (find in Foundry: Dataset > Overview > Resource identifier) --
VISION_STREAM_RID=<your-vision-stream-rid>
GRIP_STREAM_RID=<your-grip-stream-rid>
TELEMETRY_STREAM_RID=<your-telemetry-stream-rid>

# -- Robot Identity -----------------------------------------------------------
ROBOT_ID=robot-jetson-01
ROBOT_NAME=QA Cell Robot 01

# -- Hardware (auto-discovered if not set) ------------------------------------
# Leave commented to auto-detect. Set explicitly to override discovery.
# CAMERA_DEVICE_INDEX=0          # auto-scans /dev/video* for working USB camera
# MYCOBOT_PORT=/dev/ttyUSB0      # auto-scans USB serial ports (CP210x/CH340)
MYCOBOT_BAUD=115200

# -- Mock Mode (set to true for development without hardware) -----------------
MOCK_HARDWARE=false
MOCK_FOUNDRY=false

# -- Detection mode -----------------------------------------------------------
# "color" = HSV color detection (no model needed, sorts by block color)
# "model" = YOLOv5 inference + sensor fusion (needs trained model)
DETECTION_MODE=color
MODEL_PATH=./models/yolov5n.onnx

# -- Tuning -------------------------------------------------------------------
CAPTURE_INTERVAL_SEC=1.0
CONFIDENCE_THRESHOLD=0.75
GRIP_TOLERANCE=0.65
MODEL_POLL_INTERVAL_SEC=60
COMMAND_POLL_INTERVAL_SEC=1
HEARTBEAT_INTERVAL_SEC=5
